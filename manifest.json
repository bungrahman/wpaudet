{
  "manifest_version": 3,
  "name": "WPAudet",
   "version": "1.0.5",
  "description": "Detects WordPress themes and plugins in real-time. Now with Keyword Traffic Insight features: External Traffic Insights, AI Traffic Potential Estimation, AI Smart Cache, and Stealth Detection.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://ip-api.com/*",
    "https://rdap.verisign.com/*",
    "https://rdap.org/*",
    "https://*.rdap.org/*",
    "https://rdap.pandi.id/*",
    "https://rdap.publicinterestregistry.net/*",
    "https://dns.google/*",
    "https://edge-cdn.trakteer.id/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "wpaudet@anakbangsa.id",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}